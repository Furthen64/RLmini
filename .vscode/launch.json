{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "RLmini App",
      "type": "debugpy",
      "request": "launch",
      "module": "app.main",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "RLmini Map Editor",
      "type": "debugpy",
      "request": "launch",
      "module": "app.editor_main",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "RLmini Map Editor (sample map)",
      "type": "debugpy",
      "request": "launch",
      "module": "app.editor_main",
      "cwd": "${workspaceFolder}",
      "args": [
        "${workspaceFolder}/maps/sample_basic.map"
      ],
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Pytest: current file",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "cwd": "${workspaceFolder}",
      "args": [
        "-q",
        "${file}"
      ],
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "console": "integratedTerminal",
      "justMyCode": false
    }
  ]
}